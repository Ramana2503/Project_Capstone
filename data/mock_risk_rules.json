{
  "credit_score_thresholds": {
    "excellent": {"min": 750, "max": 850, "risk_level": "low"},
    "good": {"min": 700, "max": 749, "risk_level": "low"},
    "fair": {"min": 650, "max": 699, "risk_level": "medium"},
    "poor": {"min": 600, "max": 649, "risk_level": "high"},
    "very_poor": {"min": 0, "max": 599, "risk_level": "very_high"}
  },
  "debt_to_income_thresholds": {
    "excellent": {"min": 0, "max": 20, "risk_level": "low"},
    "good": {"min": 20, "max": 36, "risk_level": "low"},
    "fair": {"min": 36, "max": 50, "risk_level": "medium"},
    "poor": {"min": 50, "max": 100, "risk_level": "high"},
    "very_poor": {"min": 100, "max": 999, "risk_level": "very_high"}
  },
  "employment_risk": {
    "full_time": {"multiplier": 1.0, "risk_factor": 0},
    "contract": {"multiplier": 1.25, "risk_factor": 0.15},
    "self_employed": {"multiplier": 1.15, "risk_factor": 0.1},
    "part_time": {"multiplier": 1.35, "risk_factor": 0.25},
    "unemployed": {"multiplier": 2.0, "risk_factor": 0.5}
  },
  "employment_stability": {
    "min_years_excellent": 5,
    "min_years_good": 2,
    "min_years_fair": 1,
    "new_employment_risk_factor": 0.3
  },
  "anomaly_detection": {
    "late_payment_threshold": 3,
    "default_accounts_threshold": 1,
    "high_existing_liability_ratio": 0.5
  },
  "approval_rules": {
    "auto_approve_credit_score": 750,
    "auto_approve_dti": 20,
    "auto_approve_combined_conditions": ["credit_score >= 700", "dti <= 36", "no_defaults"],
    "auto_reject_credit_score": 550,
    "auto_reject_dti": 80,
    "auto_reject_combined_conditions": ["credit_score <= 580", "default_accounts > 0"],
    "manual_review_conditions": ["credit_score between 600-700", "dti between 50-80", "recent_late_payments"]
  },
  "age_considerations": {
    "min_age": 18,
    "max_age": 80,
    "senior_rate_adjustment": 1.1
  }
